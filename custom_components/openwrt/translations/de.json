  "issues": {
    "auth_failed": {
      "title": "Authentifizierung für {host} fehlgeschlagen",
      "description": "Die OpenWrt Integration konnte sich nicht mit {host} authentifizieren. Die Zugangsdaten könnten sich geändert haben.\n\nBitte aktualisiere die Zugangsdaten, um die Verbindung wiederherzustellen."
    },
    "wan_down": {
      "title": "Lokales Netzwerk / WAN auf {host} unterbrochen",
      "description": "Der OpenWrt Router {host} meldet, dass das Haupt-WAN-Interface derzeit ausgeschaltet oder nicht verbunden ist. Die Internetverbindung könnte beeinträchtigt sein."
    },
    "connection_lost": {
      "title": "Verbindung zu {host} verloren",
      "description": "Home Assistant kann den OpenWrt Router unter {host} nicht mehr erreichen. Bitte überprüfe, ob das Gerät eingeschaltet und im Netzwerk erreichbar ist."
    },
    "missing_packages": {
      "title": "Fehlende empfohlene Pakete auf {host}",
      "description": "Um alle Funktionen der OpenWrt Integration optimal zu nutzen, fehlen einige Pakete auf {host}.\n\nBitte installiere die folgenden Pakete via LuCI oder SSH: `{packages}`."
    },
    "firmware_outdated": {
      "title": "OpenWrt Firmware ist veraltet auf {host}",
      "description": "Der OpenWrt Router {host} verwendet Version {current_version}, aber Version {latest_version} ist verfügbar.\n\nEs wird dringend empfohlen, die Firmware des Routers aus Sicherheitsgründen aktuell zu halten. Die neueste Version kann [hier]({release_url}) heruntergeladen werden."
    }
