{
  "config": {
    "step": {
      "user": {
        "title": "Verbindung zum OpenWrt Router",
        "description": "Wähle die Verbindungsmethode für deinen OpenWrt Router. Ubus wird dringend empfohlen, da es alle Funktionen unterstützt. [Mehr erfahren]({docs_url}).",
        "data": {
          "host": "Host (IP-Adresse oder Hostname)",
          "connection_type": "Verbindungstyp"
        }
      },
      "credentials": {
        "title": "Authentifizierung",
        "description": "Gib die Zugangsdaten für {host} via {connection_type} ein.",
        "data": {
          "username": "Benutzername",
          "password": "Passwort",
          "use_ssl": "SSL/HTTPS verwenden",
          "verify_ssl": "SSL-Zertifikat überprüfen",
          "port": "Port",
          "ubus_path": "Ubus Pfad (z.B. /ubus)"
        }
      },
      "ssh": {
        "title": "SSH Authentifizierung",
        "description": "Gib die SSH Zugangsdaten für {host} ein.",
        "data": {
          "username": "Benutzername",
          "password": "Passwort",
          "ssh_key": "Privater SSH Schlüssel (Optional, lässt das Passwort leer, falls verwendet)",
          "port": "Port"
        }
      },
      "reauth_confirm": {
        "title": "Neu authentifizieren",
        "description": "Die Zugangsdaten für den OpenWrt Router sind nicht mehr gültig. Bitte gib das neue Passwort ein.",
        "data": {
          "username": "Benutzername",
          "password": "Passwort"
        }
      },
      "ssdp_confirm": {
        "title": "OpenWrt Router gefunden",
        "description": "Möchten Sie {name} ({host}) einrichten? Die Verbindung wird über ubus (HTTP/HTTPS) hergestellt.",
        "data": {
          "username": "Benutzername",
          "password": "Passwort",
          "use_ssl": "SSL (HTTPS) nutzen",
          "port": "Port (Optional)"
        }
      },
      "permissions": {
        "title": "Berechtigungsübersicht",
        "description": "Basierend auf den Anmeldedaten wurden folgende Berechtigungen erkannt:\n\n{permissions_table}\n\nDu kannst fortfahren, wenn dies erwartet wird."
      }
    },
    "error": {
      "cannot_connect": "Verbindung zum Router fehlgeschlagen. Prüfe IP/Host und ob der Dienst (ubus/LuCI/SSH) läuft.",
      "invalid_auth": "Ungültige Zugangsdaten (Benutzername, Passwort oder SSH-Key).",
      "timeout": "Zeitüberschreitung der Verbindung. Prüfe die Erreichbarkeit und den Port.",
      "ssl_error": "SSL-Verifizierung fehlgeschlagen. Deaktiviere 'SSL-Zertifikat prüfen' bei selbstsignierten Zertifikaten.",
      "package_missing": "Erforderliches OpenWrt Paket fehlt. Für ubus: 'uhttpd-mod-ubus'. Für LuCI: 'luci-mod-rpc'. Installation via SSH: 'opkg update && opkg install <paket>'.",
