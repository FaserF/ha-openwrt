{
  "domain": "openwrt",
  "name": "OpenWrt",
  "codeowners": [
    "@FaserF"
  ],
  "config_flow": true,
  "dependencies": [
    "ssdp"
  ],
  "documentation": "https://github.com/FaserF/ha-openwrt",
  "integration_type": "hub",
  "iot_class": "local_polling",
  "issue_tracker": "https://github.com/FaserF/ha-openwrt/issues",
  "loggers": [
    "openwrt"
  ],
  "requirements": [
    "paramiko>=4.0.0"
  ],
  "ssdp": [
    {
      "st": "urn:schemas-upnp-org:device:InternetGatewayDevice:1"
    },
    {
      "st": "urn:schemas-upnp-org:device:InternetGatewayDevice:2"
    },
    {
      "st": "upnp:rootdevice"
    }
  ],
  "zeroconf": [
    {
      "type": "_http._tcp.local.",
      "name": "openwrt*"
    },
    {
      "type": "_ssh._tcp.local.",
      "name": "openwrt*"
    },
    {
      "type": "_luci._tcp.local."
    },
    {
      "type": "_http._tcp.local."
    },
    {
      "type": "_ssh._tcp.local."
    }
  ],
  "dhcp": [
    {
      "hostname": "openwrt*"
    },
    {
      "hostname": "lede*"
    },
    {
      "hostname": "librecmc*"
    },
    {
      "macaddress": "D4BC52*"
    },
    {
      "macaddress": "E848B8*"
    },
    {
      "macaddress": "000C43*"
    },
    {
      "macaddress": "B0B98A*"
    }
  ],
  "version": "1.1.0"
}