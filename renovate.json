{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs",
    ":prHourlyLimitNone",
    ":dependencyDashboard"
  ],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ],
  "python": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "regexManagers": [
    {
      "fileMatch": [
        "custom_components/openwrt/helpers/mqtt_presence.py"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+REPO_URL = \"https://raw.githubusercontent.com/[^/]+/[^/]+/(?<currentValue>[a-f0-9]+)\""
      ]
    }
  ]
}
